FRONTEND_HOST=0.0.0.0
FRONTEND_HTTP_PORT=5173
FRONTEND_HTTPS_PORT=5174
VITE_FRONTEND_TARGET=shop

# Database
# Primary runtime storage including MariaDB, PostgreSQL, or SQLite fallback.
