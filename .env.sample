# Application
APP_NAME=codexsun

# API server
APP_HOST=0.0.0.0
APP_DOMAIN=api.codexsun.local
APP_HTTP_PORT=3000
APP_HTTPS_PORT=3443

# Frontend dev server
FRONTEND_HOST=0.0.0.0
FRONTEND_DOMAIN=app.codexsun.local
FRONTEND_HTTP_PORT=5173
FRONTEND_HTTPS_PORT=5174

# TLS / Cloudflare
TLS_ENABLED=false
TLS_KEY_PATH=
TLS_CERT_PATH=
CLOUDFLARE_ENABLED=false

# Primary database
# Supported: mariadb | sqlite | postgres
# Use sqlite for local boot. Switch to mariadb for the live transactional path.
DB_DRIVER=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=codexsun
DB_USER=root
DB_PASSWORD=
DB_SSL=false

# Offline desktop support
OFFLINE_SUPPORT_ENABLED=false
SQLITE_FILE=storage/desktop/codexsun.sqlite

# Future analytics database
ANALYTICS_DB_ENABLED=false
ANALYTICS_DB_HOST=127.0.0.1
ANALYTICS_DB_PORT=5432
ANALYTICS_DB_NAME=codexsun_analytics
ANALYTICS_DB_USER=postgres
ANALYTICS_DB_PASSWORD=
ANALYTICS_DB_SSL=false

# Auth bootstrap
SUPER_ADMIN_EMAILS=admin@example.com

# Built frontend output
WEB_ROOT=build/app/cxapp/web
