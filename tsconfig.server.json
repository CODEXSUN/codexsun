{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./apps/ui/src/*"],
      "@ui/*": ["./apps/ui/src/*"],
      "@framework/*": ["./apps/framework/src/*"],
      "@cxapp/*": ["./apps/cxapp/*"],
      "@site/*": ["./apps/site/*"],
      "@core/*": ["./apps/core/*"],
      "@api/*": ["./apps/api/*"],
      "@billing/*": ["./apps/billing/*"],
      "@demo/*": ["./apps/demo/*"],
      "@ecommerce/*": ["./apps/ecommerce/*"],
      "@task/*": ["./apps/task/*"],
      "@crm/*": ["./apps/crm/*"],
      "@zetro/*": ["./apps/zetro/*"],
      "@frappe/*": ["./apps/frappe/*"],
      "@tally/*": ["./apps/tally/*"],
      "@cli/*": ["./apps/cli/*"]
    },
    "outDir": "./build/app/cxapp/server",
    "rootDir": ".",
    "sourceMap": true
  },
  "include": [
    "apps/framework/src/**/*.ts",
    "apps/framework/engines/**/*.ts",
    "apps/framework/lib/**/*.ts",
    "apps/framework/manifests/**/*.ts",
    "apps/framework/runtime/**/*.ts",
    "apps/framework/testing/**/*.ts",
    "apps/*/src/**/*.ts",
    "apps/*/database/**/*.ts",
    "apps/*/helper/**/*.ts",
    "apps/*/shared/**/*.ts"
  ],
  "exclude": [
    "apps/mobile/**"
  ]
}
