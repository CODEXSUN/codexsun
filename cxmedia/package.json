{
  "name": "cxmedia",
  "private": true,
  "version": "1.0.207",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:web": "vite -c vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "build": "tsc -p tsconfig.json && vite build -c vite.config.ts",
    "start": "node ../build/cxmedia/server.js"
  }
}
