ARG NODE_RUNTIME_VERSION=26.5.0
FROM node:${NODE_RUNTIME_VERSION}-bookworm-slim AS build

WORKDIR /workspace
ARG NPM_RUNTIME_VERSION=12.0.1
RUN npm install --global npm@${NPM_RUNTIME_VERSION}
COPY framework ./framework
COPY core ./core
COPY billing ./billing
COPY mail ./mail
COPY ui ./ui
COPY codexsun ./codexsun

WORKDIR /workspace/codexsun
RUN npm ci \
  && npm run setup \
  && npm run build \
  && npm run dependencies:check

FROM build AS migrations
ARG CODEXSUN_VERSION=1.0.42
LABEL org.opencontainers.image.title="CODEXSUN Billing Stack Migrations" \
      org.opencontainers.image.version="$CODEXSUN_VERSION"
ENV NODE_ENV=production
CMD ["npm", "run", "db:migrations:run"]

FROM build AS production-dependencies
RUN npm prune --omit=dev \
  && npm prune --omit=dev --prefix ../framework \
  && npm prune --omit=dev --prefix ../core \
  && npm prune --omit=dev --prefix ../billing \
  && npm prune --omit=dev --prefix ../mail

FROM node:${NODE_RUNTIME_VERSION}-bookworm-slim AS runtime

ARG CODEXSUN_VERSION=1.0.42
ARG NPM_RUNTIME_VERSION=12.0.1
ARG PLATFORM_API_PORT
LABEL org.opencontainers.image.title="CODEXSUN Billing Stack API" \
      org.opencontainers.image.version="$CODEXSUN_VERSION"

WORKDIR /workspace/codexsun
RUN npm install --global npm@${NPM_RUNTIME_VERSION} \
  && apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates mariadb-client \
  && rm -rf /var/lib/apt/lists/* \
  && mkdir -p /storage /workspace/codexsun/apps/platform/web/public \
  && ln -s /storage/tenants /workspace/codexsun/storage \
  && ln -s /storage/app/public /workspace/codexsun/apps/platform/web/public/storage \
  && chown -R node:node /storage /workspace

COPY --from=production-dependencies /workspace/framework /workspace/framework
COPY --from=production-dependencies /workspace/core /workspace/core
COPY --from=production-dependencies /workspace/billing /workspace/billing
COPY --from=production-dependencies /workspace/mail /workspace/mail
COPY --from=production-dependencies /workspace/codexsun /workspace/codexsun
COPY codexsun/.container/scripts/api-entrypoint.sh /usr/local/bin/codexsun-api-entrypoint

RUN cp -a /workspace/core/dist/api /workspace/core/api/dist \
  && cp -a /workspace/billing/dist/api /workspace/billing/api/dist \
  && cp -a /workspace/mail/dist/api /workspace/mail/api/dist \
  && sed -i 's#\./src/index\.ts#./dist/index.js#g; s#\./src/modules/mail/index\.ts#./dist/modules/mail/index.js#g' \
      /workspace/core/api/package.json \
      /workspace/billing/api/package.json \
      /workspace/mail/api/package.json \
  && chmod +x /usr/local/bin/codexsun-api-entrypoint
ENV NODE_ENV=production
USER node
EXPOSE ${PLATFORM_API_PORT}
HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=10 \
  CMD node -e "fetch('http://127.0.0.1:'+process.env.HEALTH_PORT+'/health').then(r=>{if(!r.ok)process.exit(1)}).catch(()=>process.exit(1))"
ENTRYPOINT ["codexsun-api-entrypoint"]
