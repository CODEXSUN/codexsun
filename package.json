{
  "name": "codexsun",
  "version": "1.0.51",
  "private": true,
  "packageManager": "npm@12.0.1",
  "description": "Complete CODEXSUN application and stack orchestrator",
  "type": "module",
  "workspaces": [
    "src/platform/*",
    "tools/*"
  ],
  "scripts": {
    "setup": "node tools/install-stack.mjs",
    "dev": "node tools/dev-stack.mjs",
    "dev:api": "node tools/preflight.mjs platform-api",
    "dev:web": "node tools/preflight.mjs platform-web",
    "build": "node tools/stack-command.mjs build",
    "typecheck": "node tools/stack-command.mjs typecheck",
    "lint": "node tools/stack-command.mjs lint",
    "check": "npm run check:text-encoding && npm run check:module-boundaries && npm run check:database-lifecycle && npm run typecheck && npm run lint",
    "check:text-encoding": "node tools/check-env-encoding.mjs",
    "check:env-encoding": "npm run check:text-encoding",
    "check:module-boundaries": "node tools/check-module-boundaries.mjs",
    "check:core-boundaries": "node tools/check-module-boundaries.mjs core",
    "check:database-lifecycle": "node tools/check-database-lifecycle.mjs",
    "dependencies:check": "node tools/check-root-node-modules.mjs",
    "version:show": "node tools/repository-release.mjs version:show",
    "version:bump": "node tools/repository-release.mjs version:bump",
    "check:versions": "node tools/repository-release.mjs check:versions",
    "github:now": "node tools/repository-release.mjs github:now",
    "stack:impact": "node tools/stack-impact.mjs",
    "stack:plan": "node tools/stack-release-plan.mjs",
    "format": "prettier . ../framework ../ui ../core ../billing ../mail --write",
    "format:check": "prettier . ../framework ../ui ../core ../billing ../mail --check",
    "test:product-stacks": "node --test tools/product-stack-contract.test.mjs",
    "test:e2e": "npm run test:e2e:queue && npm run test:e2e:organisation && npm run test:e2e:bootstrap && npm run test:e2e:persistence && npm run test:e2e:composed-runtime",
    "test:e2e:queue": "tsx tools/e2e/queue-backend.e2e.ts",
    "test:e2e:organisation": "tsx ../core/api/src/modules/organisation/organisation.e2e.ts",
    "test:e2e:bootstrap": "tsx tools/e2e/platform-core-billing-bootstrap.e2e.ts",
    "test:e2e:composed-runtime": "tsx tools/e2e/composed-platform-runtime.e2e.ts",
    "test:e2e:persistence": "tsx tools/e2e/organisation-billing-persistence.e2e.ts",
    "test:e2e:live-mass": "tsx tools/e2e/live-five-tenant-mass.e2e.ts",
    "test:e2e:tenant-access": "tsx tools/e2e/tenant-access.e2e.ts",
    "test:e2e:tenant-landing": "tsx src/platform/api/src/modules/tenant/tenant.landing.e2e.ts",
    "test:e2e:tenant-user-admin": "tsx src/platform/api/src/modules/tenant-user/tenant-user.admin.e2e.ts",
    "db:migrate": "tsx src/platform/api/src/database/db-cli.ts migrate",
    "db:migrations:list": "tsx src/platform/api/src/database/db-cli.ts migrations:list",
    "db:migrations:preflight": "tsx src/platform/api/src/database/db-cli.ts migrations:preflight",
    "db:migrations:run": "tsx src/platform/api/src/database/db-cli.ts migrations:run",
    "db:migrations:test-local": "tsx src/platform/api/src/database/db-cli.ts migrations:test-local",
    "db:seed": "tsx src/platform/api/src/database/db-cli.ts seed",
    "db:drop": "tsx src/platform/api/src/database/db-cli.ts drop",
    "dbmigrate:fresh": "tsx src/platform/api/src/database/db-cli.ts fresh",
    "db:dump:create": "tsx src/platform/api/src/database/db-cli.ts dump:create",
    "db:dump:download": "tsx src/platform/api/src/database/db-cli.ts dump:download",
    "db:restore:test": "tsx src/platform/api/src/database/db-cli.ts restore:test",
    "db:backup:verify": "tsx src/platform/api/src/database/db-cli.ts backup:verify",
    "github:ssh-key": "node tools/github-ssh-key.mjs",
    "env:jwt-secret": "node tools/env-jwt-secret.mjs"
  },
  "dependencies": {
    "@codexsun/billing": "file:../billing",
    "@codexsun/billing-api": "file:../billing/api",
    "@codexsun/billing-web": "file:../billing/web",
    "@codexsun/sites": "file:../sites",
    "@codexsun/core": "file:../core",
    "@codexsun/core-api": "file:../core/api",
    "@codexsun/core-web": "file:../core/web",
    "@codexsun/framework": "file:../framework",
    "@codexsun/mail": "file:../mail",
    "@codexsun/mail-api": "file:../mail/api",
    "@codexsun/mail-web": "file:../mail/web",
    "@codexsun/ui": "file:../ui"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.2",
    "typescript": "^7.0.2",
    "typescript-eslint-compiler": "npm:typescript@6.0.3",
    "vite": "^8.1.5"
  },
  "engines": {
    "node": ">=26.5.0",
    "npm": ">=12.0.1"
  },
  "allowScripts": {
    "esbuild": true
  }
}
